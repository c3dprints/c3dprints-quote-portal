# C3D Prints Quote Portal — backend environment
# Copy to .env and fill in. Every var below is actually read by backend/*.py.

# --- App ---
APP_NAME=C3D Prints Quote Portal
APP_ENV=production
# Comma-separated origins allowed by CORS (GitHub Pages frontend + website)
ALLOWED_ORIGINS=https://c3dprints.github.io,https://c3dprints.com,https://www.c3dprints.com
# Public URL of THIS api — used to build approval/tracking links in emails
PUBLIC_BASE_URL=https://c3dprints-quote-portal.onrender.com

# --- Admin auth ---
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Long random string used to sign admin session tokens
JWT_SECRET=

# --- Database (Supabase Postgres) ---
# Full Postgres connection string. REQUIRED — app raises on startup if missing.
DATABASE_URL=

# --- Supabase storage (uploads: STL/OBJ/images/reference files) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=quote-files

# --- Email (Resend) ---
RESEND_API_KEY=
QUOTE_NOTIFY_EMAIL=hi@c3dprints.com
FROM_EMAIL=quotes@c3dprints.com

# --- AI quote assist (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Checkout handoff links ---
SHOPIFY_CHECKOUT_URL=https://c3dprints.com/products/custom-3d-printed-cosplay-personalized-character-art-fan-art
ETSY_CHECKOUT_URL=https://c3dprintsofficial.etsy.com/listing/1249586363

# --- Storage cleanup (POST /maintenance/storage-cleanup, X-Maintenance-Key) ---
# Required to enable the cleanup endpoint; long random string.
MAINTENANCE_KEY=
# Retention windows in days before a request's stored files are freed.
CLEANUP_UNQUOTED_DAYS=90
CLEANUP_ARCHIVED_DAYS=30
CLEANUP_COMPLETED_DAYS=365

# --- Pricing calculator defaults ---
DEFAULT_KWH=0.33
DEFAULT_WATTS=180
DEFAULT_SPOOL_USD=20
DEFAULT_SPOOL_G=1000
DEFAULT_NOZZLE_COST=8
DEFAULT_NOZZLE_HOURS=400
DEFAULT_SHEET_COST=25
DEFAULT_SHEET_PRINTS=500
DEFAULT_SHIPPING=5
DEFAULT_BOXING=1.50
DEFAULT_TAX=6.25
DEFAULT_MARKUP=50
DEFAULT_LABOR_RATE=35
